GROQ_API_KEY=your_groq_api_key_here
GROQ_MODEL=llama-3.3-70b-versatile

# OpenRouter (OpenAI-compatible). Default model: ring-2.6-1t:free
# If OPENROUTER_API_KEY is set and GROQ is not, chat uses OpenRouter automatically.
# Force provider: FRIDAY_LLM_PROVIDER=groq  |  openrouter
OPENROUTER_API_KEY=your_openrouter_key_here
OPENROUTER_MODEL=ring-2.6-1t:free
# Optional OpenRouter attribution headers:
# OPENROUTER_HTTP_REFERER=http://localhost
# OPENROUTER_APP_TITLE=FRIDAY

# UI
FRIDAY_UI_VERSION=v2.0 Sentinel

# Long-term memory (mem0). Set to 0 to disable if memory causes instability.
FRIDAY_ENABLE_MEMORY=1

# TTS: auto (Kokoro if model files exist, else edge-tts) | kokoro | edge
FRIDAY_TTS_BACKEND=auto
FRIDAY_VOICE=af_heart
FRIDAY_TTS_SPEED=1.1

# Kokoro paths (when using kokoro or auto with files present)
# FRIDAY_TTS_MODEL=kokoro-v1.0.onnx
# FRIDAY_TTS_VOICES=voices-v1.0.bin

# STT (faster-whisper)
# FRIDAY_WHISPER_MODEL=small
# FRIDAY_WHISPER_DEVICE=cpu
# FRIDAY_WHISPER_COMPUTE=int8
# Live partial refresh interval (seconds)
# FRIDAY_STT_PARTIAL_INTERVAL=0.85
# FRIDAY_STT_PARTIAL_MAX_SEC=5.0
# FRIDAY_STT_MIN_HYBRID=0.38

# VAD (webrtc); mode 0–3 (higher = stricter)
# FRIDAY_VAD_MODE=2
