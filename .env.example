GROQ_API_KEY=your_groq_api_key_here
GROQ_MODEL=llama-3.3-70b-versatile

# OpenRouter (OpenAI-compatible). Default model: ring-2.6-1t:free
# If OPENROUTER_API_KEY is set and GROQ is not, chat uses OpenRouter automatically.
# Force provider: FRIDAY_LLM_PROVIDER=groq  |  openrouter
OPENROUTER_API_KEY=your_openrouter_key_here
OPENROUTER_MODEL=ring-2.6-1t:free
# Optional OpenRouter attribution headers:
# OPENROUTER_HTTP_REFERER=http://localhost
# OPENROUTER_APP_TITLE=FRIDAY

# UI
FRIDAY_UI_VERSION=v2.0 Sentinel

# Long-term memory (mem0). Set to 0 to disable if memory causes instability.
FRIDAY_ENABLE_MEMORY=1

# TTS: auto (Kokoro if model files exist, else edge-tts) | kokoro | edge
FRIDAY_TTS_BACKEND=auto
FRIDAY_VOICE=af_heart
FRIDAY_TTS_SPEED=1.1

# Kokoro paths (when using kokoro or auto with files present)
# FRIDAY_TTS_MODEL=kokoro-v1.0.onnx
# FRIDAY_TTS_VOICES=voices-v1.0.bin

# STT (faster-whisper)
# FRIDAY_WHISPER_MODEL=small
# FRIDAY_WHISPER_DEVICE=cpu
# FRIDAY_WHISPER_COMPUTE=int8

# VAD (webrtc); mode 0-3 (higher = stricter)
# FRIDAY_VAD_MODE=2

# ── Supabase — persistent storage (PostgreSQL + pgvector) ────────────────────
# Required for Render deployment. Leave blank for local SQLite/ChromaDB fallback.
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_KEY=your_supabase_service_role_key_here

# ── API Key — protects public endpoints when deployed ─────────────────────────
# If set, all requests to /api/chat/stream, /api/speak, /api/upload, etc.
# must include the header:  X-API-Key: <value>
# Leave blank for local dev (no authentication required).
FRIDAY_API_KEY=

# ── Supabase JWT Auth (frontend -> backend bearer token) ─────────────────────
# Enable to require Authorization: Bearer <supabase_access_token> on protected APIs.
FRIDAY_SUPABASE_AUTH_ENABLED=0
FRIDAY_FULL_ACCESS_EMAILS=khansaheer424@gmail.com
# Backend verification uses SUPABASE_URL + SUPABASE_ANON_KEY (or SUPABASE_KEY fallback).
SUPABASE_ANON_KEY=your_supabase_anon_key_here
# Frontend Vite env vars (set in frontend/.env or deployment env):
# VITE_SUPABASE_URL=https://your-project-ref.supabase.co
# VITE_SUPABASE_ANON_KEY=your_supabase_anon_key_here

# ── CORS — allowed origins for browser requests ───────────────────────────────
# Comma-separated. Defaults to localhost:8080 for local dev.
# Set to your Render URL when deployed.
FRIDAY_ALLOWED_ORIGINS=http://localhost:8080,http://127.0.0.1:8080
