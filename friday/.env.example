GROQ_API_KEY=your_groq_api_key_here
GROQ_MODEL=llama-3.3-70b-versatile

# OpenAI TTS (optional — only needed if TTS_BACKEND=openai)
OPENAI_API_KEY=your_openai_api_key_here
FRIDAY_VOICE=nova
FRIDAY_TTS_MODEL=tts-1-hd

# TTS Backend: "browser" (default, no keys needed) | "kokoro" (local ONNX) | "edge" (MS online)
TTS_BACKEND=browser

# Kokoro TTS model paths (only if TTS_BACKEND=kokoro)
# FRIDAY_TTS_MODEL=kokoro-v1.0.onnx
# FRIDAY_TTS_VOICES=voices-v1.0.bin
# FRIDAY_VOICE=bf_emma
# FRIDAY_TTS_SPEED=1.1
