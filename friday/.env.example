GROQ_API_KEY=your_groq_api_key_here
GROQ_MODEL=llama-3.3-70b-versatile

# TTS Backend: "browser" (default, no keys needed) | "kokoro" (local ONNX) | "edge" (MS online)
TTS_BACKEND=browser
FRIDAY_VOICE=af_heart
FRIDAY_TTS_SPEED=1.1

# Kokoro TTS model paths (only if TTS_BACKEND=kokoro)
# FRIDAY_TTS_MODEL=kokoro-v1.0.onnx
# FRIDAY_TTS_VOICES=voices-v1.0.bin
